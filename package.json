{
  "name": "seven-levels",
  "version": "1.0.0",
  "description": "THE SEVEN LEVELS — an old-school mainframe dungeon crawler",
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "build:web": "tsc -p tsconfig.web.json",
    "db:init": "NODE_NO_WARNINGS=1 tsx scripts/init-db.ts",
    "cli": "NODE_NO_WARNINGS=1 tsx src/cli/cli.ts",
    "web": "NODE_NO_WARNINGS=1 tsx src/server/server.ts",
    "test": "NODE_NO_WARNINGS=1 vitest run",
    "test:watch": "NODE_NO_WARNINGS=1 vitest"
  },
  "dependencies": {
    "express": "^4.18.3"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.0.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3",
    "vitest": "^2.1.0"
  }
}
